# Only auto-start tmux in interactive login shells over SSH or local terminal
if [[ -z "$TMUX" ]] && [[ -n "$PS1" ]] && [[ -t 1 ]]; then
  if [[ -v VSCODE_INJECTION ]]; then
    : # Do nothing in VS Code (injected environment)
  elif [[ "$TERM_PROGRAM" == "vscode" ]]; then
    : # Explicitly skip VS Code terminal
  elif command -v tmux >/dev/null 2>&1; then
    # Define session name (consistent across reboots)
    SESSION_NAME="main"

    # Check if a tmux server is already running with this session
    if tmux has-session -t "$SESSION_NAME" 2>/dev/null; then
      # Session exists: attach to it (this enables resurrection!)
      exec tmux attach-session -t "$SESSION_NAME"
    else
      # No session: create new one
      exec tmux new-session -d -s "$SESSION_NAME" \; attach-session -t "$SESSION_NAME"
    fi
  fi
fi
