#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/home/ubuntu/.local/share/pnpm/global/5/.pnpm/@fission-ai+openspec@1.3.1_@types+node@25.6.0/node_modules/@fission-ai/openspec/node_modules:/home/ubuntu/.local/share/pnpm/global/5/.pnpm/@fission-ai+openspec@1.3.1_@types+node@25.6.0/node_modules:/home/ubuntu/.local/share/pnpm/global/5/.pnpm/node_modules"
else
  export NODE_PATH="/home/ubuntu/.local/share/pnpm/global/5/.pnpm/@fission-ai+openspec@1.3.1_@types+node@25.6.0/node_modules/@fission-ai/openspec/node_modules:/home/ubuntu/.local/share/pnpm/global/5/.pnpm/@fission-ai+openspec@1.3.1_@types+node@25.6.0/node_modules:/home/ubuntu/.local/share/pnpm/global/5/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../../.local/share/pnpm/global/5/.pnpm/@fission-ai+openspec@1.3.1_@types+node@25.6.0/node_modules/@fission-ai/openspec/bin/openspec.js" "$@"
else
  exec node  "$basedir/../../.local/share/pnpm/global/5/.pnpm/@fission-ai+openspec@1.3.1_@types+node@25.6.0/node_modules/@fission-ai/openspec/bin/openspec.js" "$@"
fi
