{
  "$schema": "https://openclaw.ai/schema/config.v1.json",
  "gateway": {
    "bind": "local",
    "port": 18789,
    "auth": {
      "mode": "token",
      "token": "0cccbedfb661cefb0cea5ad3b866b75d1106fdcdccc12fdd"
    }
  },
  "agents": {
    "list": [
      {
        "id": "main",
        "model": "bailian/qwen3-coder-next"
      },
      {
        "id": "opencode",
        "runtime": {
          "type": "acp",
          "acp": {
            "agent": "opencode",
            "backend": "acpx",
            "mode": "persistent",
            "cwd": "/workspace"
          }
        }
      }
    ],
    "defaults": {
      "model": "bailian/qwen3-coder-next"
    }
  },
  "acp": {
    "enabled": true,
    "backend": "acpx",
    "defaultAgent": "opencode",
    "allowedAgents": ["opencode", "codex", "claude", "pi", "gemini"],
    "maxConcurrentSessions": 8,
    "stream": {
      "coalesceIdleMs": 300,
      "maxChunkChars": 1200
    },
    "runtime": {
      "ttlMinutes": 120
    }
  },
  "plugins": {
    "entries": {
      "acpx": {
        "enabled": true,
        "config": {
          "command": "/home/ubuntu/.bun/install/global/node_modules/openclaw/dist/extensions/acpx",
          "expectedVersion": "any",
          "permissionMode": "approve-all",
          "nonInteractivePermissions": "deny"
        }
      }
    }
  },
  "tools": {
    "elevated": {
      "security": "allowlist",
      "allowlist": ["read", "write", "edit", "exec", "glob", "grep"]
    }
  },
  "commands": {
    "text": true,
    "native": "auto",
    "nativeSkills": "auto"
  },
  "session": {
    "threadBindings": {
      "enabled": true,
      "idleHours": 50,
      "maxAgeHours": 0
    }
  },
  "channels": {
    "webchat": {
      "threadBindings": {
        "enabled": true,
        "spawnAcpSessions": true
      }
    },
    "feishu": {
      "capabilities": ["threadBindings", "acpSessions"],
      "threadBindings": {
        "enabled": true,
        "spawnAcpSessions": true
      }
    }
  }
}
