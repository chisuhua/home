## 列出所有 changes 的状态

如果不带参数：

```bash
echo "Active Changes:"
openspec list --json | jq -r '.[] | "\(.)"'
echo ""

for CHANGE in $(openspec list --json | jq -r '.[] | @base64'); do
    CHANGE_NAME=$(echo "$CHANGE" | base64 -d)
    APPLY=$(openspec instructions apply --change "$CHANGE_NAME" --json 2>/dev/null)
    if [ $? -eq 0 ]; then
        PROGRESS=$(echo "$APPLY" | jq '.progress')
        STATE=$(echo "$APPLY" | jq -r '.state')
        echo "├── $CHANGE_NAME ($PROGRESS.complete/$PROGRESS.total) - $STATE"
    fi
done
```

