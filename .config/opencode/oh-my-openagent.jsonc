{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-opencode/master/assets/oh-my-opencode.schema.json",
  "agents": {
    "title": {
      "model": "bailian-coding-plan/qwen3-max"
    },
    "sisyphus": {
      "model": "bailian-coding-plan/qwen3.5-plus",
      "prompt_append": "\n\nALWAYS follow this workflow: 1) Use superpowers/tdd to generate tests, 2) Implement code, 3) Run superpowers/code-review. Never skip steps.\n\nBenchmark: qwen3.5-plus 代码质量 95 分，综合评分第 1 (93 分)"
    },
    "sisyphus-junior": {
      "model": "minimax/MiniMax-M2.7-highspeed"
    },
    "oracle": {
      "model": "bailian-coding-plan/qwen3.5-plus",
      "prompt_append": "\n\nValidate plans with superpowers/writing-plans skill before outputting. Prioritize speed and clarity.\n\nBenchmark: qwen3.5-plus 架构分析最佳"
    },
    "librarian": {
      "model": "bailian-coding-plan/kimi-k2.5"
    },
    "explore": {
      "model": "bailian-coding-plan/qwen3-max"
    },
    "multimodal-looker": {
      "model": "bailian-coding-plan/kimi-k2.5"
    },
    "prometheus": {
      "model": "bailian-coding-plan/qwen3.5-plus",
      "prompt_append": "\n\nYou are Prometheus, the planning agent. ALWAYS use the superpowers/writing-plans skill to produce structured, testable, and actionable development plans with clear completion criteria.\n\nBenchmark: qwen3.5-plus 规划质量 95 分"
    },
    "metis": {
      "model": "minimax/MiniMax-M2.7-highspeed"
    },
    "critic": {
      "model": "minimax/MiniMax-M2.7-highspeed"
    },
    "momus": {
      "model": "bailian-coding-plan/qwen3.5-plus",
      "prompt_append": "\n\nYou are Momus, the plan critic. Use the superpowers/momus skill to rigorously evaluate the feasibility, completeness, and risk of any proposed plan. Demand testability and clear success criteria."
    },
    "atlas": {
      "model": "bailian-coding-plan/qwen3-coder-next"
    },
    "batch": {
      "model": "bailian-coding-plan/qwen3-coder-next"
    },
    "hephaestus": {
      "model": "minimax/MiniMax-M2.7-highspeed",
      "prompt_append": "\n\nYou are Hephaestus, specialist in complex C++ (templates, memory safety, performance). Use cpp-* skills when applicable.\n\nBenchmark: qwen3-coder-plus 代码质量 88 分，MiniMax-M2.7 92 分备选"
    },
    "quick": {
      "model": "bailian-coding-plan/qwen3-max"
    },
    "build": {
      "model": "bailian-coding-plan/qwen3-coder-plus"
    },
    "review": {
      "model": "bailian-coding-plan/qwen3.5-plus"
    },
    "monarch": {
      "model": "bailian-coding-plan/qwen3.5-plus"
    }
  },
  "categories": {
    "ultrabrain": {
      "model": "bailian-coding-plan/qwen3.5-plus"
    },
    "unspecified-high": {
      "model": "bailian-coding-plan/qwen3-coder-plus"
    },
    "unspecified-low": {
      "model": "bailian-coding-plan/qwen3-coder-next"
    },
    "visual-engineering": {
      "model": "bailian-coding-plan/qwen3-coder-next"
    },
    "deep": {
      "model": "bailian-coding-plan/qwen3.5-plus"
    },
    "writing": {
      "model": "bailian-coding-plan/kimi-k2.5"
    },
    "cpp": {
      "model": "minimax/MiniMax-M2.7-highspeed"
    },
    "cuda": {
      "model": "bailian-coding-plan/qwen3.5-plus"
    },
    "review": {
      "model": "bailian-coding-plan/qwen3.5-plus"
    }
  }
}
